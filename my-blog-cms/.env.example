# Server Configuration
HOST=0.0.0.0
PORT=1337

# Security Secrets (Generate new values for production)
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database Configuration
# =====================
# Development: Uses PostgreSQL on localhost
# Production: Uses MariaDB with environment variables
#
# The database client is automatically selected based on NODE_ENV:
# - NODE_ENV=development (or not set): Uses PostgreSQL
# - NODE_ENV=production: Uses MariaDB (mysql client)

# PostgreSQL Configuration (Development)
# --------------------------------------
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/strapi_db_leqta
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi_db_leqta
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password
DATABASE_SCHEMA=public

# MariaDB Configuration (Production)
# -----------------------------------
# Uncomment and set these in production environment
# DATABASE_CLIENT=mysql
# DATABASE_HOST=your_mariadb_host
# DATABASE_PORT=3306
# DATABASE_NAME=your_database_name
# DATABASE_USERNAME=your_username
# DATABASE_PASSWORD=your_password
# DATABASE_SSL=false

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

# Supabase Storage Configuration
# ==============================
SUPABASE_BUCKET=your_bucket_name
SUPABASE_API_URL=https://your-project-ref.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key
SUPABASE_DIRECTORY=
